{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run main.py (Integrated Terminal)",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/main.py"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "runOptions": {
                "reevaluateOnRerun": true
            }
        }
    ]
}